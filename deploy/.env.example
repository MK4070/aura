# Application Settings
APP_PORT=:8080
LOG_LEVEL=debug
ENVIRONMENT=dev

# Kafka Configuration
KAFKA_BROKERS=aura-redpanda:9092
KAFKA_TOPIC=
KAFKA_CONSUMER_MAX_RETRY=3
KAFKA_CONSUMER_WORKERS=16

# Database Configuration
# Format: postgres://username:password@host:port/database_name
DB_USER=postgres
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=
DATABASE_URL="postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable"

# Ollama
OLLAMA_HOST="aura-ollama:11434"
EMBED_MODEL="nomic-embed-text"

# Qdrant
QDRANT_COLLECTION=
QDRANT_GRPC_PORT=6334
QDRANT_HOST=aura-qdrant

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT="http://aura-otel:4317"